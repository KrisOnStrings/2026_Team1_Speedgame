# Unity .gitignore

# This .gitignore should be placed in the root of your Unity project

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset Bundles

/[Aa]ssetBundles/

# Addressables build content

/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.json

# User-specific settings

/[Uu]ser[Ss]ettings/

# Visual Studio / Rider

.vs/
.idea/
.gradle/

# Visual Studio files

*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj

# Rider

*.DotSettings.user

# MonoDevelop

*.pidb.meta

# Unity generated

*.tmp
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Crash reports

sysinfo.txt

# OS generated files

.DS_Store
Thumbs.db
Desktop.ini

# JetBrains caches

.idea/

# Build outputs

*.apk
*.aab
*.ipa

# Test results

TestResults/

# Generated packages

*.tgz

# Ignore exported packages

*.unitypackage

# Ignore cache server

/[Cc]ache/

# Ignore profiler captures

*.data
*.raw

#########################################################################

# IMPORTANT: KEEP THESE FOLDERS IN SOURCE CONTROL

#########################################################################
#!Assets/
#!Packages/
#!ProjectSettings/

# Meta files must be committed

# Make sure "Visible Meta Files" is enabled in Unity

#########################################################################
